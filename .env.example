DATABASE_URL=postgresql://user:password@host:5432/db

# MootsKeeper frontend origin used for OAuth redirect callbacks
FRONTEND_URL=https://mootskeeper.com

# Twitch OAuth (optional if you only use InkScout SSO)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Google OAuth (optional if you only use InkScout SSO)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# InkScout Supabase token validation (required for InkScout pseudo-SSO)
INKSCOUT_SUPABASE_URL=https://your-project-id.supabase.co
INKSCOUT_SUPABASE_ANON_KEY=your_supabase_anon_key
